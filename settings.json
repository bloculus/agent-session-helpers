{
  "permissions": {
    "allow": [
      "Skill(session_save)",
      "Skill(session_handoff)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash $(git rev-parse --show-toplevel 2>/dev/null)/.claude/hooks/pre_tool_use_hook.sh"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "startup",
        "hooks": [
          {
            "type": "command",
            "command": "bash $(git rev-parse --show-toplevel 2>/dev/null)/.claude/hooks/session_start_hook.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash $(git rev-parse --show-toplevel 2>/dev/null)/.claude/hooks/stop_hook.sh"
          }
        ]
      }
    ]
  }
}
